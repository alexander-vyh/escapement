{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/project-bootstrap.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/session_cleanup.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/mol_status_check.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/serena_onboarding_check.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_no_shirking.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/implementation_echo_test_gate.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/oracle_downgrade_warning_gate.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/serena_preference_gate.py"
          }
        ]
      },
      {
        "matcher": "Bash(gh pr create:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/outcome_assertion_gate.py"
          }
        ]
      },
      {
        "matcher": "Bash(bd create:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/discovery-gate.py"
          }
        ]
      },
      {
        "matcher": "Bash(bd close:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/discovery-close-gate.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/review_gate.py"
          }
        ]
      },
      {
        "matcher": "Bash(bd update:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/review_gate.py"
          }
        ]
      },
      {
        "matcher": "Bash(bd create:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/spec_id_enforcement.py"
          }
        ]
      },
      {
        "matcher": "Bash(openspec:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/openspec_init_guard.py"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/enforce_named_agents.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context_burn_detector.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/review_gate.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__serena__replace_symbol_body",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_after_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_before_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/serena_preference_gate.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context_burn_detector.py"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context_burn_detector.py"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context_burn_detector.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/discovery-nudge.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/review_nudge.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/serena_preference_injection.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/design_doc_location_guard.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_reminder.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/design_doc_location_guard.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/test_reminder.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_no_shirking.py"
          }
        ]
      }
    ]
  }
}
