{
  "description": "Escapement workflow gates: oracle discipline, TDD enforcement, beads tracking, outcome-bias continuation, and serena-first navigation.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/session_cleanup.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/session_status.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/mol_status_check.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/serena_onboarding_check.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/harness/bin/session_watermark.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/harness/bin/reconcile_incidents.py\" --quiet",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/validate_no_shirking.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/implementation_echo_test_gate.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/oracle_downgrade_warning_gate.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/serena_preference_gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/cache_write_guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/harness/bin/task_mode_entry.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(gh pr create:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/outcome_assertion_gate.py\""
          }
        ]
      },
      {
        "matcher": "Bash(gh pr merge:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/merge_authorization_gate.py\""
          }
        ]
      },
      {
        "matcher": "Bash(bd create:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/discovery-gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/spec_id_enforcement.py\""
          }
        ]
      },
      {
        "matcher": "Bash(bd close:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/openspec_task_reconciliation_gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/discovery-close-gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/review_gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/epic_coverage_gate.py\""
          }
        ]
      },
      {
        "matcher": "Bash(bd update:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/review_gate.py\""
          }
        ]
      },
      {
        "matcher": "Bash(openspec:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/openspec_init_guard.py\""
          }
        ]
      },
      {
        "matcher": "Bash(git worktree add:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/beads_worktree_guard.py\""
          }
        ]
      },
      {
        "matcher": "Bash(git:*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/beads_worktree_guard.py\""
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/enforce_named_agents.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/context_burn_detector.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/review_gate.py\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/tdd-gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/discovery_input_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/gate_design_nudge.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/tdd-gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/discovery_input_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/gate_design_nudge.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/tdd-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__serena__replace_symbol_body",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/tdd-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_after_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/tdd-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_before_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/tdd-gate.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__plugin_slack_slack__slack_send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/no_direct_send_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__plugin_slack_slack__slack_schedule_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/no_direct_send_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Slack__slack_send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/no_direct_send_guard.py\""
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Slack__slack_schedule_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/no_direct_send_guard.py\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/serena_preference_gate.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/context_burn_detector.py\""
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/context_burn_detector.py\""
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/context_burn_detector.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/discovery-nudge.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/review_nudge.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/serena_preference_injection.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/design_doc_location_guard.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_reminder.py\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/design_doc_location_guard.py\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/test_reminder.py\""
          }
        ]
      },
      {
        "matcher": "ScheduleWakeup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/harness/bin/schedule_wakeup_bridge.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/claude/hooks/validate_no_shirking.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/harness/bin/stop_hook.py\""
          }
        ]
      }
    ]
  }
}
