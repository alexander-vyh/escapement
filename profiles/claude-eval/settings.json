{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/validate_no_shirking.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/implementation_echo_test_gate.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/oracle_downgrade_warning_gate.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/serena_preference_gate.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/cache_write_guard.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/enforce_named_agents.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/context_burn_detector.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/review_gate.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/discovery_input_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/gate_design_nudge.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/file_complexity_gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/discovery_input_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/gate_design_nudge.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/file_complexity_gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/file_complexity_gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__serena__replace_symbol_body",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_after_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_before_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_oracle_brief_gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/tdd-gate.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/serena_preference_gate.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/context_burn_detector.py"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/context_burn_detector.py"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/context_burn_detector.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/discovery-nudge.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/review_nudge.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/serena_preference_injection.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/design_doc_location_guard.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_reminder.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/design_doc_location_guard.py"
          },
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/test_reminder.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/hooks/validate_no_shirking.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -B ~/.claude/harness/bin/stop_hook.py"
          }
        ]
      }
    ]
  }
}
