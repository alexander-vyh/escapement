{
  "name": "escapement-claude-eval",
  "version": 1,
  "host": "claude-code",
  "description": "Portable Claude Code eval profile for Escapement workflow gates.",
  "source_repo": "escapement",
  "settings": {
    "gates": "settings.json",
    "workflow": "settings.workflow.json"
  },
  "installer": "install.sh",
  "doctor": "doctor.py",
  "auth_included": false,
  "designed_for": [
    "SWE-bench patch-generation A/B runs",
    "Terminal-Bench custom Claude host adapters",
    "custom hook/workflow adversarial tasks"
  ],
  "installed_surfaces": {
    "hooks": "claude/hooks/*.py and claude/hooks/*.sh",
    "skills": "claude/skills/*",
    "rules": "claude/rules/*.md",
    "commands": "claude/commands/*.md",
    "agents": "claude/agents/*.md",
    "harness": "harness/bin/*.py, harness/bin/verify, harness/schemas/*",
    "beads_formulas": "beads/formulas/*.json, beads/mol-status.sh when installed with --profile workflow"
  },
  "required_hooks": [
    "validate_no_shirking.py",
    "test_oracle_brief_gate.py",
    "tdd-gate.py",
    "implementation_echo_test_gate.py",
    "oracle_downgrade_warning_gate.py",
    "file_complexity_gate.py",
    "serena_preference_gate.py",
    "context_burn_detector.py",
    "design_doc_location_guard.py",
    "test_reminder.py",
    "stop_hook.py"
  ],
  "required_workflow_hooks": [
    "bd prime",
    "session_status.py",
    "mol_status_check.py",
    "discovery-gate.py",
    "spec_id_enforcement.py",
    "openspec_task_reconciliation_gate.py",
    "discovery-close-gate.py",
    "epic_coverage_gate.py",
    "openspec_init_guard.py",
    "beads_worktree_guard.py",
    "outcome_assertion_gate.py"
  ],
  "excluded_surfaces": [
    "Claude authentication/session state",
    "provider/model selection",
    "personal permissions",
    "project-bootstrap.sh auto-init",
    "launchd services"
  ]
}
