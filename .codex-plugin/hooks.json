{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime",
            "statusMessage": "Loading Escapement workflow context",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime",
            "statusMessage": "Refreshing Escapement workflow context",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "statusMessage": "Checking Test Oracle Brief gate",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/implementation_echo_test_gate.py\"",
            "statusMessage": "Checking for implementation-echo tests",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/oracle_downgrade_warning_gate.py\"",
            "statusMessage": "Checking for oracle downgrade",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/discovery-gate.py\"",
            "statusMessage": "Checking discovery gate (design doc required for feature creates)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/outcome_assertion_gate.py\"",
            "statusMessage": "Checking outcome assertion quality (on gh pr create)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/spec_id_enforcement.py\"",
            "statusMessage": "Checking spec-id backlink on mol-feature task creates",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/epic_coverage_gate.py\"",
            "statusMessage": "Checking epic seam coverage before close",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "statusMessage": "Checking Test Oracle Brief gate",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/claude/hooks/test_oracle_brief_gate.py\"",
            "statusMessage": "Checking Test Oracle Brief gate",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
