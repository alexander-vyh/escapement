# Backups produced by INSTALL.sh (should never be committed)
*.backup-*

# OS cruft
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Python test artifacts
__pycache__/
.pytest_cache/
*.pyc

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Harness + hook runtime artifacts (written at runtime, not deliverables)
.claude/scheduled_tasks.lock
claude/hooks/agent-dispatch.log
claude/hooks/state/
